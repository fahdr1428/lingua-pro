  "frameworks": [
    {
      "id": "sov",
      "title": "Word order: SOV",
      "body": "Bengali puts the verb at the END. 'I rice eat' instead of 'I eat rice'. The same pattern as Hindi and Urdu — once you master one, the others click faster."
    },
    {
      "id": "honorifics",
      "title": "Three levels of 'you'",
      "body": "তুই (intimate/close), তুমি (familiar), আপনি (formal). Use তুই only with very close friends or younger family — using it with a stranger is rude."
    },
    {
      "id": "no-gender",
      "title": "No grammatical gender",
      "body": "Unlike Urdu and Hindi, Bengali nouns don't have gender. সে means both 'he' and 'she'. Major simplification compared to its sister languages."
    },
    {
      "id": "phonetic",
      "title": "Bangla script is phonetic",
      "body": "Each letter represents one sound. Once you learn the script (about 50 characters), you can pronounce ANY Bengali word — no spelling chaos like English."
    }
  ],
