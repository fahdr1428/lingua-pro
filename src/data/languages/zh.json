  "frameworks": [
    {
      "id": "tones",
      "title": "Tones change meaning",
      "body": "Mā (mother), má (hemp), mǎ (horse), mà (scold). Same syllable, four meanings. Tones aren't optional — they're the word."
    },
    {
      "id": "no-conj",
      "title": "No verb conjugation",
      "body": "Verbs don't change for tense or person. Time is shown with words like 昨天 (yesterday) or 了 (past marker)."
    },
    {
      "id": "measure",
      "title": "Measure words",
      "body": "You can't say 'three book' — you need a measure word: 三本书 (three [volume] books)."
    }
  ],
