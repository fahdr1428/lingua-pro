  "frameworks": [
    {
      "id": "sov",
      "title": "Word order: SOV",
      "body": "Hindi puts the verb last, like Urdu. 'I water drink' (मैं पानी पीता हूँ). The grammar is nearly identical to Urdu."
    },
    {
      "id": "gender",
      "title": "Gender + verb agreement",
      "body": "Verbs change based on the gender of the subject. लड़का खाता है (boy eats) vs लड़की खाती है (girl eats)."
    },
    {
      "id": "phonetic",
      "title": "Devanagari is phonetic",
      "body": "Each letter = one sound. No silent letters, no spelling chaos. Once you know the script, you can pronounce ANY Hindi word."
    }
  ],
