  "frameworks": [
    {
      "id": "ser-estar",
      "title": "Ser vs Estar",
      "body": "Both mean 'to be'. Ser = permanent (I am tall). Estar = temporary (I am tired)."
    },
    {
      "id": "gender",
      "title": "Gendered nouns",
      "body": "Every noun is masculine (el) or feminine (la). Adjectives must agree."
    },
    {
      "id": "drop-subj",
      "title": "Endings carry the subject",
      "body": "'Hablo' already means 'I speak' — Spanish often drops 'yo'."
    },
    {
      "id": "two-pasts",
      "title": "Two past tenses",
      "body": "Preterite (specific event) vs Imperfect (ongoing). English collapses these."
    }
