  "frameworks": [
    {
      "id": "roots",
      "title": "Root system: 3 letters carry meaning",
      "body": "Most words come from 3-letter roots. K-T-B → kitab (book), katib (writer), maktab (office), maktaba (library). Learn roots and vocabulary explodes."
    },
    {
      "id": "rtl",
      "title": "Reads right to left",
      "body": "Letters change shape based on position (start/middle/end of word). Same letter, four forms. Practice writing — it cements recognition."
    },
    {
      "id": "no-be",
      "title": "No 'is' in present tense",
      "body": "'The house big' = the house IS big. The verb 'to be' simply isn't used in the present. Cleaner than English."
    },
    {
      "id": "diglossia",
      "title": "Diglossia: written ≠ spoken",
      "body": "Modern Standard Arabic (MSA) is for news and books. Each region has its own dialect for daily life. Start with MSA."
    }
  ],
