  "frameworks": [
    {
      "id": "sov",
      "title": "Word order: SOV",
      "body": "Japanese ends sentences with the verb. 'I sushi eat' (私は寿司を食べる). The particle は marks topic, を marks object."
    },
    {
      "id": "particles",
      "title": "Particles do the heavy lifting",
      "body": "Tiny words like は, を, に, で tell you what role each word plays. Word order is flexible — particles aren't."
    },
    {
      "id": "scripts",
      "title": "Three writing systems",
      "body": "Hiragana (native), Katakana (foreign), Kanji (Chinese characters). Learn hiragana first — you can survive on it alone."
    },
    {
      "id": "polite",
      "title": "Politeness levels",
      "body": "Casual (食べる), polite (食べます), honorific (召し上がる). Use the wrong one and you'll seem rude or weirdly formal."
    }
  ],
