  "frameworks": [
    {
      "id": "particles",
      "title": "Particles do the heavy lifting",
      "body": "은/는 mark topic, 이/가 mark subject, 을/를 mark object. Word order is flexible because particles tell you who's doing what."
    },
    {
      "id": "sov",
      "title": "Word order: SOV",
      "body": "Korean ends sentences with the verb. '나는 밥을 먹어요' = 'I rice eat'."
    },
    {
      "id": "honorifics",
      "title": "Politeness levels",
      "body": "안녕 (casual), 안녕하세요 (polite), 안녕하십니까 (formal). Match the right level to who you're talking to or sound rude/weird."
    }
